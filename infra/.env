# Configuração local de desenvolvimento — copie para .env e ajuste
# Nunca commite o arquivo .env

# PostgreSQL
POSTGRES_DB=seed_educa
POSTGRES_USER=seed_user
POSTGRES_PASSWORD=seed_pass

# JWT — mesmo segredo em todos os serviços
JWT_SECRET=troque-por-um-segredo-forte-em-producao

# MinIO (armazenamento de certificados)
MINIO_ROOT_USER=seed_minio_user
MINIO_ROOT_PASSWORD=seed_minio_pass

# Grafana (opcional — padrão é admin/admin)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
