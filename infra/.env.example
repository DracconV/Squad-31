# Configuração local de desenvolvimento — copie para .env e ajuste se necessário
# Nunca commite o arquivo .env

# PostgreSQL
POSTGRES_DB=seed_educa
POSTGRES_USER=seed_user
POSTGRES_PASSWORD=seed_pass

# MinIO (armazenamento de arquivos — certificados e imagens de questões)
MINIO_ROOT_USER=seed_minio_user
MINIO_ROOT_PASSWORD=seed_minio_pass

# Grafana (opcional — padrão é admin/admin)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
