{
  "info": {
    "_postman_id": "seed-educa-full-2026",
    "name": "SEED Educa — API Completa",
    "description": "Coleção completa de todos os endpoints dos microserviços do SEED Educa, via API Gateway (http://localhost:8080).\n\nComo usar:\n1. Suba o projeto: `docker compose up -d --build`\n2. Rode **Autenticação > Login (admin)** — o token JWT é salvo automaticamente na variável {{token}} e usado em todas as requisições.\n3. Para testar outros perfis, altere matricula/senha no Login (ex: aluno-em / seed@2025).\n\nVariáveis de ID ({{questaoId}}, {{simuladoId}}, etc.) devem ser preenchidas com valores reais retornados pelos GETs de listagem.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Injeta o JWT salvo em todas as requisições, exceto as rotas públicas.",
          "const token = pm.collectionVariables.get('token');",
          "const url = pm.request.url.toString();",
          "const publicas = ['/auth/login', '/auth/primeiro-acesso', '/auth/solicitar-redefinicao', '/auth/redefinir-senha', '/verificar-certificado'];",
          "const ehPublica = publicas.some((p) => url.indexOf(p) !== -1);",
          "if (token && !ehPublica) {",
          "  pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token });",
          "} else if (!token && !ehPublica) {",
          "  console.warn('Token vazio — rode \"Autenticação > Login (admin)\" primeiro.');",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Considera sucesso qualquer 2xx (200 OK, 201 Created, 204 No Content).",
          "pm.test('Sucesso (2xx) — HTTP ' + pm.response.code, function () {",
          "  pm.expect(pm.response.code, 'status').to.be.within(200, 299);",
          "});"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "instituicaoId", "value": "00000000-0000-0000-0000-000000000001" },
    { "key": "usuarioId", "value": "" },
    { "key": "alunoId", "value": "" },
    { "key": "turmaId", "value": "" },
    { "key": "disciplinaId", "value": "" },
    { "key": "questaoId", "value": "" },
    { "key": "alternativaId", "value": "" },
    { "key": "simuladoId", "value": "" },
    { "key": "cursoId", "value": "" },
    { "key": "moduloId", "value": "" },
    { "key": "inscricaoId", "value": "" },
    { "key": "slotId", "value": "" },
    { "key": "agendamentoId", "value": "" },
    { "key": "certificadoId", "value": "" },
    { "key": "qrCode", "value": "" },
    { "key": "resetToken", "value": "" }
  ],
  "item": [
    {
      "name": "1. Autenticação (ms-autenticacao)",
      "item": [
        {
          "name": "Login (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  console.log('Token salvo:', json.token.substring(0, 20) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"matricula\": \"admin\",\n  \"senha\": \"seed@2025\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "description": "Perfis de teste (senha: seed@2025): admin, adminescola, professor01, aluno-em, aluno-eja, aluno-prof"
          }
        },
        {
          "name": "Primeiro acesso (troca de senha)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"matricula\": \"aluno-novo\",\n  \"senhaTemporaria\": \"temp123\",\n  \"novaSenha\": \"novaSenha123\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/primeiro-acesso", "host": ["{{baseUrl}}"], "path": ["auth", "primeiro-acesso"] }
          }
        },
        {
          "name": "Me (valida token)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Solicitar redefinição de senha",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.token) { pm.collectionVariables.set('resetToken', json.token); }"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"matricula\": \"aluno-em\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/solicitar-redefinicao", "host": ["{{baseUrl}}"], "path": ["auth", "solicitar-redefinicao"] }
          }
        },
        {
          "name": "Redefinir senha (com token)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"novaSenha\": \"novaSenha123\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/redefinir-senha", "host": ["{{baseUrl}}"], "path": ["auth", "redefinir-senha"] }
          }
        }
      ]
    },
